# Environment configuration for the CES aggregates & variance pipeline.
#
# Copy to `.env` (git-ignored) or export these in your shell / scheduler.
# All values below are placeholders: the repository intentionally contains no
# real infrastructure identifiers. See `settings.py` for how each one is used.

# --- Object storage ---------------------------------------------------------
# Bucket holding the parquet files behind the external tables.
CES_STORAGE_BUCKET=<storage-bucket>
CES_STORAGE_BUCKET_EDP=<storage-bucket-edp>

# --- Filesystem locations ---------------------------------------------------
# Shared drives in the original deployment; any writable path works.
CES_LOG_DIR=/path/to/logs
CES_CACHE_DIR=/path/to/cache
CES_OUTPUT_ROOT=/path/to/data-management/output
CES_PROB_BINS_INPUT_DIR=/path/to/matlab/prob_bins
CES_DISSEMINATION_ARCHIVE_DIR=/path/to/dissemination/archive
CES_CODELIST_PATH=/path/to/ces_codelist.xml
CES_EDP_WORK_DIR=/path/to/edp/work

# --- SDMX registry endpoints ------------------------------------------------
# Acceptance (pre-production) and production SDMX registries.
CES_REGISTRY_ACC=https://<sdmx-registry-acc>/ws/public/sdmxapi/rest/
CES_REGISTRY_PROD=https://<sdmx-registry-prod>/ws/public/sdmxapi/rest/
CES_REGISTRY_HOST_ACC=https://<sdmx-registry-acc>
CES_REGISTRY_HOST_PROD=https://<sdmx-registry-prod>
